<?xml version="1.0"?>
<configuration>

  <appSettings>
    <add key="ValidationSettings:UnobtrusiveValidationMode" value="None" />
  </appSettings>

  <connectionStrings>
    <add name="StudySyncDb"
         connectionString="Data Source=(LocalDB)\MSSQLLocalDB;Initial Catalog=StudySyncDB_FinalProject_Clean;Integrated Security=True;MultipleActiveResultSets=True"
         providerName="System.Data.SqlClient" />
  </connectionStrings>

  <system.web>
    <compilation debug="true" targetFramework="4.7.2" />
    <httpRuntime targetFramework="4.7.2" />
  </system.web>



  <system.webServer>
    <defaultDocument enabled="true">
      <files>
        <clear />
        <add value="Default.aspx" />
        <add value="Home.aspx" />
      </files>
    </defaultDocument>
  </system.webServer>

</configuration>